generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================= USER =================
model User {
  id        String   @id
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  properties   Property[]
  subscription Subscription?
}

// ================= SUBSCRIPTION =================
model Subscription {
  id        String @id @default(cuid())
  userId    String @unique
  tier      SubscriptionTier @default(FREE)
  status    SubStatus        @default(ACTIVE)

  user User @relation(fields: [userId], references: [id])
}

// ================= PROPERTY =================
model Property {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  address   String
  city      String?
  deletedAt DateTime?

  complaintToken String @unique

  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id])
  rooms Room[]
  complaints Complaint[]

  @@index([ownerId])
}

// ================= ROOM =================
model Room {
  id         String @id @default(cuid())
  propertyId String

  roomNumber String
  price      Int

  status     RoomStatus @default(VACANT)
  deletedAt  DateTime?

  property Property @relation(fields: [propertyId], references: [id])
  tenants  Tenant[]
  complaints Complaint[]

  @@unique([propertyId, roomNumber])
}

// ================= TENANT =================
model Tenant {
  id        String @id @default(cuid())
  roomId    String

  name      String
  phone     String

  startDate DateTime
  endDate   DateTime?

  isActive  Boolean @default(true)

  billingCycle String // MONTHLY
  billingDay   Int    // 1–31

  room Room @relation(fields: [roomId], references: [id])
  invoices Invoice[]

  @@index([roomId, isActive])
}

// ================= INVOICE =================
model Invoice {
  id        String   @id @default(cuid())
  tenantId  String

  amount    Int
  dueDate   DateTime

  status    InvoiceStatus @default(UNPAID)

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  paymentTransactions PaymentTransaction[]

  @@index([tenantId, dueDate])
}

// ================= PAYMENT TRANSACTION =================
model PaymentTransaction {
  id         String @id @default(cuid())
  invoiceId  String

  amount     Int
  method     PaymentMethod
  status     PaymentStatus

  externalId String?

  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

// ================= COMPLAINT =================
model Complaint {
  id          String @id @default(cuid())
  propertyId  String
  roomId      String?

  roomNumber  String
  tenantName  String

  title       String
  description String

  status      ComplaintStatus @default(OPEN)
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])
  room     Room?    @relation(fields: [roomId], references: [id])
}

// ================= ENUM =================
enum RoomStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum PaymentMethod {
  CASH
  MIDTRANS
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum SubscriptionTier {
  FREE
  PRO
  MULTI
}

enum SubStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}
